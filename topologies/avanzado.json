    {
      "name": "R1",
      "type": "dynamips",
      "template": "c7200",
      "left": 330,
      "top": 55,
      "icon": "Router.png",
      "image": "c7200-adventerprisek9-mz.152-4.S6.image",
      "ram": 256,
      "nvram": 256,
      "idlepc": "0x60d6b1a8",
      "slot1": "PA-FE-TX",
      "slot2": "PA-FE-TX",
      "delay": 0,
      "bootstrap": {
        "mode": "console",
        "wait_seconds": 240,
        "lines": [
          "",
          "",
          "enable",
          "terminal length 0",
          "conf t",
          "no ip domain-lookup",
          "service dhcp",
          "interface FastEthernet0/0",
          " no ip address",
          " no shutdown",
          "exit",
          "interface FastEthernet0/0.10",
          " encapsulation dot1Q 10",
          " ip address 192.168.10.1 255.255.255.128",
          " ip access-group ACL_VLAN10_IN in",
          "exit",
          "interface FastEthernet0/0.20",
          " encapsulation dot1Q 20",
          " ip address 192.168.10.129 255.255.255.128",
          "exit",
          "interface FastEthernet1/0",
          " ip address 10.10.10.1 255.255.255.252",
          " no shutdown",
          "exit",
          "ip dhcp excluded-address 192.168.10.1 192.168.10.9",
          "ip dhcp excluded-address 192.168.10.129 192.168.10.137",
          "ip dhcp pool VLAN10",
          " network 192.168.10.0 255.255.255.128",
          " default-router 192.168.10.1",
          "exit",
          "ip dhcp pool VLAN20",
          " network 192.168.10.128 255.255.255.128",
          " default-router 192.168.10.129",
          "exit",
          "ip access-list extended ACL_VLAN10_IN",
          " deny ip 192.168.10.0 0.0.0.127 192.168.10.128 0.0.0.127",
          " permit ip any any",
          "exit",
          "router ospf 1",
          " router-id 1.1.1.1",
          " passive-interface default",
          " no passive-interface FastEthernet1/0",
          " network 192.168.10.0 0.0.0.255 area 0",
          " network 10.10.10.0 0.0.0.3 area 0",
          "exit",
          "end",
          "wr mem"
        ]
      }
    },
