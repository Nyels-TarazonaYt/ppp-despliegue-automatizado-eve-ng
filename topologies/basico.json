      },
      "b": {
        "node": "SWITCH1",
        "iface": "e0/2"
      }
    },
    {
      "a": {
        "node": "SWITCH1",
        "iface": "e0/0"
      },
      "b": {
        "node": "R1",
        "iface": "fa1/0"
      }
    }
  ]
